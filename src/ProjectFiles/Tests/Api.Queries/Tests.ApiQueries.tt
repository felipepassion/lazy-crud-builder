<#@ include file="..\..\project.tt" #>
<#@ include file="..\Tests.Common.ttinclude" #>
<#
    InitTestVariables();
    if (_testEntities.Any()) {
    foreach(var namespaces in _testGroupEntities) {
        var aggName = namespaces.Key.Split('.').FirstOrDefault(x=>x.EndsWith("Agg"));
        foreach(var entity in namespaces) {
            var queryModelName = entity.Name + "QueryModel";
            var testClassName = entity.Name + "QueryModelTests";
            var queryNs = GetSutNamespace(entity.Namespace.FullName, null, null, "Entities", "Queries.Models");
            var queryFullType = queryNs + "." + queryModelName;
            WriteAutoGeneratedHeader("ApiQueries", entity.Name);
#>

using System.Text.Json;
using Xunit;

namespace <#= GetTestNamespace("ApiQueries") #>;

public class <#= testClassName #>
{
    [Fact]
    public void <#= queryModelName #>_Should_Be_Instantiable()
    {
        var qm = new <#= queryFullType #>();
        Assert.NotNull(qm);
    }

    [Fact]
    public void <#= queryModelName #>_Should_Serialize()
    {
        var qm = new <#= queryFullType #>();
        var json = JsonSerializer.Serialize(qm);
        Assert.False(string.IsNullOrWhiteSpace(json));

        var deserialized = JsonSerializer.Deserialize<<#= queryFullType #>>(json);
        Assert.NotNull(deserialized);
    }

    [Fact]
    public void <#= queryModelName #>_OrderBy_Should_Accept_Value()
    {
        var qm = new <#= queryFullType #>();
        qm.OrderBy = "Id";
        Assert.Equal("Id", qm.OrderBy);
    }
}
<#      SaveOutputToSubFolder(
            folderName: GetTestOutputPath(),
            outputFileName: $"{aggName}.{testClassName}.g.cs",
            recreateFileIfExists: true);
        } // foreach entity
    } // foreach namespace
} // if #>
