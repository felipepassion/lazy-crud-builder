<#@ include file="..\..\ProjectFiles\Tests\Tests.Common.ttinclude" #>
<# if (entitiesT4.Any()) { 
    foreach(var namespaces in groupEntitiesT4) {
        var aggName = namespaces.Key.Split('.').FirstOrDefault(x=>x.EndsWith("Agg"));
        foreach(var entity in namespaces) {
            var queryModelName = $"{entity.Name}QueryModel";
            var testClassName = $"{entity.Name}QueryModelTests";
            var properties = GetProperties(entity, includeBase: false, includeParent: false);
            WriteAutoGeneratedHeader("Api.Queries", entity.Name);
#>

using Xunit;
using System.Text.Json;

namespace <#= NamespaceForTests("Api.Queries", aggName) #>;

/// <summary>
/// Auto-generated tests for QueryModel — <#= queryModelName #>.
/// Validates query model structure and serialization.
/// </summary>
public class <#= testClassName #>
{
    [Fact]
    public void <#= queryModelName #>_Should_Be_Instantiable()
    {
        // Arrange & Act
        var queryModel = new <#= GetDefaultNamespace() #>.Test.Domain.Aggregates.<#= aggName #>.Queries.Models.<#= queryModelName #>();

        // Assert
        Assert.NotNull(queryModel);
    }

    [Fact]
    public void <#= queryModelName #>_Should_Have_Default_Pagination()
    {
        // Arrange & Act
        var queryModel = new <#= GetDefaultNamespace() #>.Test.Domain.Aggregates.<#= aggName #>.Queries.Models.<#= queryModelName #>();

        // Assert — QueryModel base should provide pagination properties
        Assert.NotNull(queryModel);
    }

    [Fact]
    public void <#= queryModelName #>_Should_Be_Serializable()
    {
        // Arrange
        var queryModel = new <#= GetDefaultNamespace() #>.Test.Domain.Aggregates.<#= aggName #>.Queries.Models.<#= queryModelName #>();

        // Act
        var json = JsonSerializer.Serialize(queryModel);
        var deserialized = JsonSerializer.Deserialize<<#= GetDefaultNamespace() #>.Test.Domain.Aggregates.<#= aggName #>.Queries.Models.<#= queryModelName #>>(json);

        // Assert
        Assert.NotNull(json);
        Assert.NotNull(deserialized);
    }

<# foreach(var property in properties.Take(3)) { // Test first 3 properties
    var propName = property.Key;
    var propType = property.Value.Type.AsString;
    if (propType == "string" || propType == "string?") { #>
    [Fact]
    public void <#= queryModelName #>_<#= propName #>_Should_Filter()
    {
        // Arrange
        var queryModel = new <#= GetDefaultNamespace() #>.Test.Domain.Aggregates.<#= aggName #>.Queries.Models.<#= queryModelName #>();
        var testValue = "test-filter-<#= propName.ToLower() #>";

        // Act
        queryModel.<#= propName #> = testValue;

        // Assert
        Assert.Equal(testValue, queryModel.<#= propName #>);
    }

<# } } #>
    [Fact]
    public void <#= queryModelName #>_Should_Support_OrderBy()
    {
        // Arrange
        var queryModel = new <#= GetDefaultNamespace() #>.Test.Domain.Aggregates.<#= aggName #>.Queries.Models.<#= queryModelName #>();

        // Act
        queryModel.OrderBy = "Id";

        // Assert
        Assert.Equal("Id", queryModel.OrderBy);
    }

    [Fact]
    public void <#= queryModelName #>_Should_Support_Pagination()
    {
        // Arrange
        var queryModel = new <#= GetDefaultNamespace() #>.Test.Domain.Aggregates.<#= aggName #>.Queries.Models.<#= queryModelName #>();

        // Act
        queryModel.Page = 2;
        queryModel.PageSize = 50;

        // Assert
        Assert.Equal(2, queryModel.Page);
        Assert.Equal(50, queryModel.PageSize);
    }
}
<#      SaveOutputToSubFolder(
            folderName: GetTestOutputPath(), 
            outputFileName: $"{aggName}.{testClassName}.g.cs", 
            recreateFileIfExists: true);
        } // foreach entity
    } // foreach namespace
} // if #>
