<#@ include file="..\..\ProjectFiles\Tests\Tests.Common.ttinclude" #>
<# if (entitiesT4.Any()) { 
    foreach(var namespaces in groupEntitiesT4) {
        var aggName = namespaces.Key.Split('.').FirstOrDefault(x=>x.EndsWith("Agg"));
        foreach(var entity in namespaces) {
            var dtoName = entity.Name + "DTO";
            var testClassName = NormalizeDtoTestClassName(entity.Name);
            var properties = GetProperties(entity, includeBase: false, includeParent: false);
            WriteAutoGeneratedHeader("Application.DTO", entity.Name);
#>

using System.Text.Json;
using Xunit;

namespace <#= NamespaceForTests("Application.DTO", aggName) #>;

/// <summary>
/// Auto-generated tests for DTO <#= dtoName #>.
/// </summary>
public class <#= testClassName #>
{
    [Fact]
    public void <#= dtoName #>_Should_Be_Instantiable()
    {
        // Arrange & Act
        var dto = new <#= GetDefaultNamespace() #>.Test.Application.DTO.Aggregates.<#= aggName #>.Requests.<#= dtoName #>();

        // Assert
        Assert.NotNull(dto);
    }

    [Fact]
    public void <#= dtoName #>_Should_Be_Serializable()
    {
        // Arrange
        var dto = new <#= GetDefaultNamespace() #>.Test.Application.DTO.Aggregates.<#= aggName #>.Requests.<#= dtoName #>();

        // Act
        var json = JsonSerializer.Serialize(dto);
        var deserialized = JsonSerializer.Deserialize<<#= GetDefaultNamespace() #>.Test.Application.DTO.Aggregates.<#= aggName #>.Requests.<#= dtoName #>>(json);

        // Assert
        Assert.NotNull(json);
        Assert.NotNull(deserialized);
    }

    [Fact]
    public void <#= dtoName #>_Should_RoundTrip_Serialize()
    {
        // Arrange
        var dto = new <#= GetDefaultNamespace() #>.Test.Application.DTO.Aggregates.<#= aggName #>.Requests.<#= dtoName #>();
<# foreach(var property in properties) {
    var propName = property.Key;
    var propType = property.Value.Type.AsString;
    if (propType == "string" || propType == "string?") { #>
        dto.<#= propName #> = "sample-<#= propName.ToLower() #>";
<# } } #>

        // Act
        var json = JsonSerializer.Serialize(dto);
        var deserialized = JsonSerializer.Deserialize<<#= GetDefaultNamespace() #>.Test.Application.DTO.Aggregates.<#= aggName #>.Requests.<#= dtoName #>>(json);

        // Assert
        Assert.NotNull(deserialized);
<# foreach(var property in properties) {
    var propName = property.Key;
    var propType = property.Value.Type.AsString;
    if (propType == "string" || propType == "string?") { #>
        Assert.Equal(dto.<#= propName #>, deserialized.<#= propName #>);
<# } } #>
    }
}
<#      SaveOutputToSubFolder(
            folderName: GetTestOutputPath(), 
            outputFileName: $"{aggName}.{testClassName}.g.cs", 
            recreateFileIfExists: true);
        } // foreach entity
    } // foreach namespace
} // if #>
