<#@ include file="..\..\project.tt" #>
<#@ include file="..\Tests.Common.ttinclude" #>
<#
    InitTestVariables();
    if (_testEntities.Any()) {
    foreach(var namespaces in _testGroupEntities) {
        var aggName = namespaces.Key.Split('.').FirstOrDefault(x=>x.EndsWith("Agg"));
        foreach(var entity in namespaces) {
            var dtoName = entity.Name + "DTO";
            var testClassName = NormalizeDtoTestClassName(entity.Name);
            var dtoNamespace = GetSutNamespace(entity.Namespace.FullName, "Domain", "Application.DTO", "Entities", "Requests");
            var dtoFullType = dtoNamespace + "." + dtoName;
            var properties = GetProperties(entity, includeBase: false, includeParent: false);
            WriteAutoGeneratedHeader("DTO", entity.Name);
#>

using System.Text.Json;
using Xunit;

namespace <#= GetTestNamespace("DTO") #>;

public class <#= testClassName #>
{
    [Fact]
    public void <#= dtoName #>_Should_Be_Instantiable()
    {
        var dto = new <#= dtoFullType #>();
        Assert.NotNull(dto);
    }

    [Fact]
    public void <#= dtoName #>_Should_Serialize_And_Deserialize()
    {
        var dto = new <#= dtoFullType #>();
<# foreach(var property in properties) {
    var propName = property.Key;
    var propType = property.Value.Type.AsString;
    if (propType == "string" || propType == "string?") { #>
        dto.<#= propName #> = "sample-<#= propName.ToLower() #>";
<# } } #>

        var json = JsonSerializer.Serialize(dto);
        Assert.False(string.IsNullOrWhiteSpace(json));

        var deserialized = JsonSerializer.Deserialize<<#= dtoFullType #>>(json);
        Assert.NotNull(deserialized);
<# foreach(var property in properties) {
    var propName = property.Key;
    var propType = property.Value.Type.AsString;
    if (propType == "string" || propType == "string?") { #>
        Assert.Equal(dto.<#= propName #>, deserialized.<#= propName #>);
<# } } #>
    }
}
<#      SaveOutputToSubFolder(
            folderName: GetTestOutputPath(),
            outputFileName: $"{aggName}.{testClassName}.g.cs",
            recreateFileIfExists: true);
        } // foreach entity
    } // foreach namespace
} // if #>
