<#@ include file="..\..\project.tt" #>
<#@ include file="..\Tests.Common.ttinclude" #>
<#
    InitTestVariables();
    if (_testEntities.Any()) {
    foreach(var namespaces in _testGroupEntities) {
        var aggName = namespaces.Key.Split('.').FirstOrDefault(x=>x.EndsWith("Agg"));
        foreach(var entity in namespaces) {
            var appServiceName = "I" + entity.Name + "AppService";
            var testClassName = entity.Name + "AppServiceTests";
            var appInterfaceNs = GetSutNamespace(entity.Namespace.FullName, "Domain", "Application", "Entities", "Interfaces");
            WriteAutoGeneratedHeader("Application", entity.Name);
#>

using Xunit;

namespace <#= GetTestNamespace("Application") #>;

public class <#= testClassName #>
{
    [Fact]
    public void <#= appServiceName #>_Type_Should_Exist()
    {
        var type = typeof(<#= appInterfaceNs #>.<#= appServiceName #>);
        Assert.NotNull(type);
        Assert.True(type.IsInterface, "<#= appServiceName #> should be an interface.");
    }

    [Fact]
    public void <#= appServiceName #>_Should_Have_Methods()
    {
        var type = typeof(<#= appInterfaceNs #>.<#= appServiceName #>);
        var methods = type.GetMethods();
        Assert.True(methods.Length > 0,
            $"{type.Name} should declare or inherit at least one method.");
    }
}
<#      SaveOutputToSubFolder(
            folderName: GetTestOutputPath(),
            outputFileName: $"{aggName}.{testClassName}.g.cs",
            recreateFileIfExists: true);
        } // foreach entity
    } // foreach namespace
} // if #>
