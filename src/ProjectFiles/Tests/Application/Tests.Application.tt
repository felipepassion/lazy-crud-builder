<#@ include file="..\..\ProjectFiles\Tests\Tests.Common.ttinclude" #>
<# if (entitiesT4.Any()) { 
    foreach(var namespaces in groupEntitiesT4) {
        var aggName = namespaces.Key.Split('.').FirstOrDefault(x=>x.EndsWith("Agg"));
        foreach(var entity in namespaces) {
            var appServiceName = $"I{entity.Name}AppService";
            var testClassName = $"{entity.Name}AppServiceTests";
            WriteAutoGeneratedHeader("Application", entity.Name);
#>

using Xunit;

namespace <#= NamespaceForTests("Application", aggName) #>;

/// <summary>
/// Auto-generated tests for Application layer — <#= entity.Name #> aggregate.
/// </summary>
public class <#= testClassName #>
{
    [Fact]
    public void <#= entity.Name #>_AppService_Interface_Should_Exist()
    {
        // Validates that the app service interface type is discoverable at compile time.
        var type = typeof(<#= GetDefaultNamespace() #>.Test.Application.Aggregates.<#= aggName #>.Interfaces.<#= appServiceName #>);
        Assert.NotNull(type);
    }

    [Fact]
    public void <#= entity.Name #>_AppService_Interface_Should_Have_Methods()
    {
        // Arrange
        var type = typeof(<#= GetDefaultNamespace() #>.Test.Application.Aggregates.<#= aggName #>.Interfaces.<#= appServiceName #>);

        // Act
        var methods = type.GetMethods();

        // Assert
        Assert.True(methods.Length > 0,
            $"{type.Name} should declare or inherit at least one method.");
    }
}
<#      SaveOutputToSubFolder(
            folderName: GetTestOutputPath(), 
            outputFileName: $"{aggName}.{testClassName}.g.cs", 
            recreateFileIfExists: true);
        } // foreach entity
    } // foreach namespace
} // if #>
