<#@ include file="..\..\project.tt" #>
<#@ include file="..\Tests.Common.ttinclude" #>
<#
    InitTestVariables();
    if (_testEntities.Any()) {
    foreach(var namespaces in _testGroupEntities) {
        var aggName = namespaces.Key.Split('.').FirstOrDefault(x=>x.EndsWith("Agg"));
        foreach(var entity in namespaces) {
            var testClassName = NormalizeTestClassName(entity.Name);
            var properties = GetProperties(entity, includeBase: false, includeParent: false);
            WriteAutoGeneratedHeader("Domain", entity.Name);
#>

using Xunit;
using <#= entity.Namespace.FullName #>;

namespace <#= GetTestNamespace("Domain") #>;

public class <#= testClassName #>
{
    [Fact]
    public void <#= entity.Name #>_Should_Be_Instantiable()
    {
        var entity = new <#= entity.Name #>();
        Assert.NotNull(entity);
    }

    [Fact]
    public void <#= entity.Name #>_ToString_Should_Not_Be_Empty()
    {
        var entity = new <#= entity.Name #>();
        var result = entity.ToString();
        Assert.False(string.IsNullOrWhiteSpace(result),
            "<#= entity.Name #>.ToString() should not return empty.");
    }
<# foreach(var property in properties) {
    var propName = property.Key;
    var propType = property.Value.Type.AsString;
    var isString = propType == "string" || propType == "string?";
    var isNullable = propType.EndsWith("?");
    if (isString) { #>

    [Fact]
    public void <#= entity.Name #>_<#= propName #>_Should_Accept_Value()
    {
        var entity = new <#= entity.Name #>();
        entity.<#= propName #> = "test-value";
        Assert.Equal("test-value", entity.<#= propName #>);
    }
<# } else if (!isString && isNullable) { #>

    [Fact]
    public void <#= entity.Name #>_<#= propName #>_Should_Be_Nullable()
    {
        var entity = new <#= entity.Name #>();
        entity.<#= propName #> = default;
        Assert.Null(entity.<#= propName #>);
    }
<# } else { #>

    [Fact]
    public void <#= entity.Name #>_<#= propName #>_Should_Have_Default_Value()
    {
        var entity = new <#= entity.Name #>();
        var value = entity.<#= propName #>;
        Assert.Equal(default(<#= propType #>), value);
    }
<# } } #>
}
<#      SaveOutputToSubFolder(
            folderName: GetTestOutputPath(),
            outputFileName: $"{aggName}.{testClassName}.g.cs",
            recreateFileIfExists: true);
        } // foreach entity
    } // foreach namespace
} // if #>
