<#@ include file="..\..\project.tt" #>
<#@ include file="..\Tests.Common.ttinclude" #>
<#
    InitTestVariables();

    // Collect enum types referenced by entity properties in this aggregate
    var enumSet = new HashSet<string>();
    var enumInfos = new List<KeyValuePair<string, CodeEnumPropertyInfo>>();
    foreach(var entity in _testEntities) {
        var props = GetProperties(entity, includeBase: false, includeParent: false);
        foreach(var p in props) {
            try {
                var ft = FindType(p.Value.Type.CodeType.FullName.Replace("?",""));
                if (ft is EnvDTE.CodeEnum) {
                    var ce = ft as EnvDTE.CodeEnum;
                    if (enumSet.Add(ce.FullName)) {
                        enumInfos.Add(new KeyValuePair<string, CodeEnumPropertyInfo>(
                            ce.FullName, GetProperties(ce)));
                    }
                }
            } catch { /* skip non-resolvable types */ }
        }
    }

    if (enumInfos.Any()) {
        var aggName = _testAggName;
        var testClassName = aggName + "EnumerationsTests";
        WriteAutoGeneratedHeader("Enumerations", aggName);
#>

using Xunit;

namespace <#= GetTestNamespace("Enumerations") #>;

public class <#= testClassName #>
{
<# foreach(var kv in enumInfos) {
    var enumFullName = kv.Key;
    var enumInfo = kv.Value;
    var safeName = SanitizeIdentifier(enumInfo.TypeName);
#>
    [Fact]
    public void <#= safeName #>_Should_Have_Values()
    {
        var values = System.Enum.GetValues(typeof(<#= enumFullName #>));
        Assert.NotEmpty(values);
    }

    [Fact]
    public void <#= safeName #>_Should_Parse_First_Value()
    {
        var first = System.Enum.GetValues(typeof(<#= enumFullName #>)).GetValue(0)!;
        var parsed = System.Enum.Parse(typeof(<#= enumFullName #>), first.ToString()!);
        Assert.Equal(first, parsed);
    }

<# } #>
}
<#      SaveOutputToSubFolder(
            folderName: GetTestOutputPath(),
            outputFileName: $"{aggName}.{testClassName}.g.cs",
            recreateFileIfExists: true);
} else {
    // no enums found — emit a skip-marker test so the pipeline still succeeds
    WriteAutoGeneratedHeader("Enumerations", "None");
#>

using Xunit;

namespace <#= GetTestNamespace("Enumerations") #>;

public class NoEnumerationsTests
{
    [Fact(Skip = "No enumerations found in this aggregate.")]
    public void Placeholder() { }
}
<#  SaveOutputToSubFolder(
        folderName: GetTestOutputPath(),
        outputFileName: "NoEnumerations.g.cs",
        recreateFileIfExists: true);
} #>
} // if enumTypes.Any()
#>
