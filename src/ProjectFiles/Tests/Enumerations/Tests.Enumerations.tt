<#@ include file="..\..\ProjectFiles\Tests\Tests.Common.ttinclude" #>
<# 
// Enumerations test template — generates tests for enum types in the domain
var enumTypes = entitiesT4
    .SelectMany(e => e.GetMembers().OfType<EnvDTE.CodeEnum>())
    .Distinct()
    .ToList();

if (enumTypes.Any()) {
    foreach(var namespaces in groupEntitiesT4) {
        var aggName = namespaces.Key.Split('.').FirstOrDefault(x=>x.EndsWith("Agg"));
        
        // Get enums from this aggregate
        var aggrEnums = enumTypes
            .Where(e => e.Namespace?.FullName?.Contains(aggName) == true)
            .ToList();
        
        if (!aggrEnums.Any()) continue;
        
        WriteAutoGeneratedHeader("Enumerations", aggName);
#>

using Xunit;
using System;

namespace <#= NamespaceForTests("Enumerations", aggName) #>;

/// <summary>
/// Auto-generated tests for Enumerations in <#= aggName #> aggregate.
/// Validates enum parsing, values, and ToString behavior.
/// </summary>
public class <#= aggName #>EnumerationsTests
{
<# foreach(var enumType in aggrEnums) { 
    var enumName = enumType.Name;
    var members = enumType.Members.Cast<EnvDTE.CodeElement>().ToList();
#>
    [Fact]
    public void <#= enumName #>_Should_Have_Members()
    {
        // Arrange
        var enumType = typeof(<#= enumType.Namespace.FullName #>.<#= enumName #>);

        // Act
        var values = Enum.GetValues(enumType);

        // Assert
        Assert.NotEmpty(values);
        Assert.True(values.Length > 0, "<#= enumName #> should have at least one member.");
    }

    [Fact]
    public void <#= enumName #>_Should_Parse_From_String()
    {
        // Arrange
        var enumType = typeof(<#= enumType.Namespace.FullName #>.<#= enumName #>);
        var firstValue = Enum.GetValues(enumType).GetValue(0);
        var stringValue = firstValue.ToString();

        // Act
        var parsed = Enum.Parse(enumType, stringValue);

        // Assert
        Assert.NotNull(parsed);
        Assert.Equal(firstValue, parsed);
    }

    [Fact]
    public void <#= enumName #>_ToString_Should_Return_Name()
    {
        // Arrange
        var enumType = typeof(<#= enumType.Namespace.FullName #>.<#= enumName #>);
        var firstValue = Enum.GetValues(enumType).GetValue(0);

        // Act
        var stringValue = firstValue.ToString();

        // Assert
        Assert.False(string.IsNullOrWhiteSpace(stringValue),
            "<#= enumName #>.ToString() should return the enum member name.");
    }

    [Theory]
<# 
    var memberNames = members.Take(5).Select(m => m.Name).ToList();
    foreach(var memberName in memberNames) { 
#>
    [InlineData("<#= memberName #>")]
<# } #>
    public void <#= enumName #>_Should_Parse_Valid_Members(string memberName)
    {
        // Arrange
        var enumType = typeof(<#= enumType.Namespace.FullName #>.<#= enumName #>);

        // Act
        var canParse = Enum.TryParse(enumType, memberName, out var result);

        // Assert
        Assert.True(canParse, $"Should be able to parse '{memberName}' as <#= enumName #>");
        Assert.NotNull(result);
    }

    [Fact]
    public void <#= enumName #>_Should_Reject_Invalid_Parse()
    {
        // Arrange
        var enumType = typeof(<#= enumType.Namespace.FullName #>.<#= enumName #>);
        var invalidValue = "Invalid_<#= enumName #>_Value_XYZ";

        // Act
        var canParse = Enum.TryParse(enumType, invalidValue, out _);

        // Assert
        Assert.False(canParse, $"Should not parse invalid value '{invalidValue}' as <#= enumName #>");
    }

<# } #>
}
<#      SaveOutputToSubFolder(
            folderName: GetTestOutputPath(), 
            outputFileName: $"{aggName}.EnumerationsTests.g.cs", 
            recreateFileIfExists: true);
    } // foreach namespace
} else {
    // No enums found — generate a placeholder comment
    WriteAutoGeneratedHeader("Enumerations", "None");
#>

// No enumerations found in the current aggregate.
// This file was generated as a placeholder.

<#  SaveOutputToSubFolder(
        folderName: GetTestOutputPath(), 
        outputFileName: "NoEnumerations.g.cs", 
        recreateFileIfExists: true);
} // if enumTypes.Any()
#>
