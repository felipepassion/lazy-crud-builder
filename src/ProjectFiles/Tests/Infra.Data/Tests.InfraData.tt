<#@ include file="..\..\ProjectFiles\Tests\Tests.Common.ttinclude" #>
<# if (entitiesT4.Any()) { 
    foreach(var namespaces in groupEntitiesT4) {
        var aggName = namespaces.Key.Split('.').FirstOrDefault(x=>x.EndsWith("Agg"));
        foreach(var entity in namespaces) {
            var repoInterfaceName = $"I{entity.Name}Repository";
            var testClassName = $"{entity.Name}InfraDataTests";
            WriteAutoGeneratedHeader("Infra.Data", entity.Name);
#>

using Xunit;

namespace <#= NamespaceForTests("Infra.Data", aggName) #>;

/// <summary>
/// Auto-generated tests for Infra.Data layer — <#= entity.Name #> aggregate.
/// </summary>
public class <#= testClassName #>
{
    [Fact]
    public void <#= entity.Name #>_Repository_Interface_Should_Exist()
    {
        // Validates that the repository interface type is discoverable at compile time.
        var type = typeof(<#= GetDefaultNamespace() #>.Test.Domain.Aggregates.<#= aggName #>.Repositories.<#= repoInterfaceName #>);
        Assert.NotNull(type);
    }

    [Fact]
    public void <#= entity.Name #>_Repository_Interface_Should_Be_Interface()
    {
        // Arrange
        var type = typeof(<#= GetDefaultNamespace() #>.Test.Domain.Aggregates.<#= aggName #>.Repositories.<#= repoInterfaceName #>);

        // Assert
        Assert.True(type.IsInterface,
            $"{type.Name} should be an interface.");
    }

    [Fact]
    public void <#= entity.Name #>_Mapping_Type_Should_Exist()
    {
        // Validates that the entity mapping class exists for EF Core.
        var mappingType = typeof(<#= GetDefaultNamespace() #>.Test.Infra.Data.Aggregates.<#= aggName #>.Mappings.<#= entity.Name #>Mapping);
        Assert.NotNull(mappingType);
    }
}
<#      SaveOutputToSubFolder(
            folderName: GetTestOutputPath(), 
            outputFileName: $"{aggName}.{testClassName}.g.cs", 
            recreateFileIfExists: true);
        } // foreach entity
    } // foreach namespace
} // if #>
