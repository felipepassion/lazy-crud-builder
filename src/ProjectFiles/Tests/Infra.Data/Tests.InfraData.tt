<#@ include file="..\..\project.tt" #>
<#@ include file="..\Tests.Common.ttinclude" #>
<#
    InitTestVariables();
    if (_testEntities.Any()) {
    foreach(var namespaces in _testGroupEntities) {
        var aggName = namespaces.Key.Split('.').FirstOrDefault(x=>x.EndsWith("Agg"));
        foreach(var entity in namespaces) {
            var repoInterfaceName = "I" + entity.Name + "Repository";
            var testClassName = entity.Name + "InfraDataTests";
            var repoNs = GetSutNamespace(entity.Namespace.FullName, null, null, "Entities", "Repositories");
            var mappingNs = GetSutNamespace(entity.Namespace.FullName, "Domain", "Infra.Data", "Entities", "Mappings");
            WriteAutoGeneratedHeader("InfraData", entity.Name);
#>

using Xunit;

namespace <#= GetTestNamespace("InfraData") #>;

public class <#= testClassName #>
{
    [Fact]
    public void <#= entity.Name #>_Repository_Interface_Should_Exist()
    {
        var type = typeof(<#= repoNs #>.<#= repoInterfaceName #>);
        Assert.NotNull(type);
        Assert.True(type.IsInterface, "<#= repoInterfaceName #> should be an interface.");
    }

    [Fact]
    public void <#= entity.Name #>_Mapping_Should_Exist()
    {
        var mappingType = typeof(<#= mappingNs #>.<#= entity.Name #>Mapping);
        Assert.NotNull(mappingType);
        Assert.True(mappingType.IsClass, "<#= entity.Name #>Mapping should be a class.");
    }
}
<#      SaveOutputToSubFolder(
            folderName: GetTestOutputPath(),
            outputFileName: $"{aggName}.{testClassName}.g.cs",
            recreateFileIfExists: true);
        } // foreach entity
    } // foreach namespace
} // if #>
