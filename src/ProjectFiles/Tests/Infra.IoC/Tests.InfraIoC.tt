<#@ include file="..\..\ProjectFiles\Tests\Tests.Common.ttinclude" #>
<# if (entitiesT4.Any()) { 
    foreach(var namespaces in groupEntitiesT4) {
        var aggName = namespaces.Key.Split('.').FirstOrDefault(x=>x.EndsWith("Agg"));
        
        // Generate one test class per aggregate (not per entity) for IoC
        WriteAutoGeneratedHeader("Infra.IoC", aggName);
#>

using Xunit;
using Microsoft.Extensions.DependencyInjection;

namespace <#= NamespaceForTests("Infra.IoC", aggName) #>;

/// <summary>
/// Auto-generated tests for Infra.IoC layer — <#= aggName #> aggregate.
/// Validates dependency injection configuration and service registration.
/// </summary>
public class <#= aggName #>IoCTests
{
    [Fact]
    public void IoCFactory_Should_Register_Services_For_<#= aggName #>()
    {
        // Arrange
        var services = new ServiceCollection();

        // Act — Attempt to resolve IoC configuration type
        var iocFactoryType = typeof(<#= GetDefaultNamespace() #>.Test.Infra.IoC.IoCFactory);

        // Assert
        Assert.NotNull(iocFactoryType);
        Assert.True(iocFactoryType.IsClass, "IoCFactory should be a class.");
    }

    [Fact]
    public void IoCFactory_Should_Have_RegisterDependencies_Method()
    {
        // Arrange
        var iocFactoryType = typeof(<#= GetDefaultNamespace() #>.Test.Infra.IoC.IoCFactory);

        // Act
        var methods = iocFactoryType.GetMethods()
            .Where(m => m.Name.Contains("Register") || m.Name.Contains("Configure"))
            .ToList();

        // Assert
        Assert.NotEmpty(methods);
    }

<# foreach(var entity in namespaces) { 
    var repoInterfaceName = $"I{entity.Name}Repository";
    var appServiceName = $"I{entity.Name}AppService";
#>
    [Fact]
    public void Should_Resolve_<#= entity.Name #>_Repository_Type()
    {
        // Validates that <#= entity.Name #> repository interface is resolvable.
        var type = typeof(<#= GetDefaultNamespace() #>.Test.Domain.Aggregates.<#= aggName #>.Repositories.<#= repoInterfaceName #>);
        
        Assert.NotNull(type);
        Assert.True(type.IsInterface, "Repository should be an interface.");
    }

    [Fact]
    public void Should_Resolve_<#= entity.Name #>_AppService_Type()
    {
        // Validates that <#= entity.Name #> application service interface is resolvable.
        var type = typeof(<#= GetDefaultNamespace() #>.Test.Application.Aggregates.<#= aggName #>.Interfaces.<#= appServiceName #>);
        
        Assert.NotNull(type);
        Assert.True(type.IsInterface, "AppService should be an interface.");
    }

<# } #>
}
<#      SaveOutputToSubFolder(
            folderName: GetTestOutputPath(), 
            outputFileName: $"{aggName}.IoCTests.g.cs", 
            recreateFileIfExists: true);
        break; // Only generate once per aggregate
    } // foreach namespace
} // if #>
