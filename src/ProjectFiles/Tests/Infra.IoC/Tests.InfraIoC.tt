<#@ include file="..\..\project.tt" #>
<#@ include file="..\Tests.Common.ttinclude" #>
<#
    InitTestVariables();
    if (_testEntities.Any()) {
    foreach(var namespaces in _testGroupEntities) {
        var aggName = namespaces.Key.Split('.').FirstOrDefault(x=>x.EndsWith("Agg"));
        var testClassName = aggName + "IoCTests";
        WriteAutoGeneratedHeader("InfraIoC", aggName);
#>

using Xunit;
using Microsoft.Extensions.DependencyInjection;

namespace <#= GetTestNamespace("InfraIoC") #>;

public class <#= testClassName #>
{
<# foreach(var entity in namespaces) {
    var repoInterfaceName = "I" + entity.Name + "Repository";
    var repoNs = GetSutNamespace(entity.Namespace.FullName, null, null, "Entities", "Repositories");
    var appInterfaceNs = GetSutNamespace(entity.Namespace.FullName, "Domain", "Application", "Entities", "Interfaces");
#>
    [Fact]
    public void Should_Resolve_<#= entity.Name #>_Repository_Type()
    {
        var type = typeof(<#= repoNs #>.<#= repoInterfaceName #>);
        Assert.NotNull(type);
        Assert.True(type.IsInterface);
    }

    [Fact]
    public void Should_Resolve_<#= entity.Name #>_AppService_Type()
    {
        var type = typeof(<#= appInterfaceNs #>.I<#= entity.Name #>AppService);
        Assert.NotNull(type);
        Assert.True(type.IsInterface);
    }

<# } #>
}
<#      SaveOutputToSubFolder(
            folderName: GetTestOutputPath(),
            outputFileName: $"{aggName}.{testClassName}.g.cs",
            recreateFileIfExists: true);
        break; // one file per aggregate
    } // foreach namespace
} // if #>
