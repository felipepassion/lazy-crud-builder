<#+
// ============================================================================
// Tests.Common.ttinclude — Shared helpers for T4-generated test files.
// Provides auto-generated headers, namespace helpers, and test scaffolding
// utilities used by all layer-specific test templates.
// ============================================================================

/// <summary>
/// Writes the standard auto-generated file header with DO NOT EDIT warning.
/// </summary>
private void WriteAutoGeneratedHeader(string layerName, string entityName)
{
#>
// <auto-generated>
//     This code was generated by a T4 template (Tests.<#= layerName #>.tt).
//     Changes to this file will be lost when the code is regenerated.
//     DO NOT EDIT this file manually.
// </auto-generated>

/// <summary>
/// Auto-generated by LazyCrud. DO NOT EDIT.
/// Generated for: <#= entityName #> in <#= layerName #> layer.
/// </summary>
<#+
}

/// <summary>
/// Builds the test namespace for a given layer and aggregate.
/// E.g. NamespaceForTests("Domain", "TestAgg") => "Lazy.Crud.Test.Domain.Aggregates.TestAgg.Tests"
/// </summary>
private string NamespaceForTests(string layerName, string aggName)
{
    return $"{GetDefaultNamespace()}.Test.{layerName}.Aggregates.{aggName}.Tests";
}

/// <summary>
/// Returns a safe test class name for an entity.
/// E.g. NormalizeTestClassName("Test") => "TestEntityTests"
/// </summary>
private string NormalizeTestClassName(string entityName, string suffix = "Tests")
{
    return $"{entityName}Entity{suffix}";
}

/// <summary>
/// Returns a safe DTO test class name.
/// E.g. NormalizeDtoTestClassName("Test") => "TestDtoTests"
/// </summary>
private string NormalizeDtoTestClassName(string entityName)
{
    return $"{entityName}DtoTests";
}

/// <summary>
/// Returns a safe controller test class name.
/// E.g. NormalizeControllerTestClassName("Test") => "TestControllerTests"
/// </summary>
private string NormalizeControllerTestClassName(string entityName)
{
    return $"{entityName}ControllerTests";
}

/// <summary>
/// Returns a safe query model test class name.
/// E.g. NormalizeQueryModelTestClassName("Test") => "TestQueryModelTests"
/// </summary>
private string NormalizeQueryModelTestClassName(string entityName)
{
    return $"{entityName}QueryModelTests";
}

/// <summary>
/// Gets the test output subfolder path for generated tests.
/// Tests are organized under Tests/Generated/<Layer>/
/// </summary>
private string GetTestOutputPath()
{
    var basePath = GetGenerationOutputPath();
    if (string.IsNullOrWhiteSpace(basePath))
        return "Tests/Generated";
    return basePath + "/Tests/Generated";
}

/// <summary>
/// Gets the test output path for a specific layer.
/// E.g. GetTestOutputPathForLayer("Domain") => "Tests/Generated/Domain"
/// </summary>
private string GetTestOutputPathForLayer(string layerName)
{
    return $"{GetTestOutputPath()}/{layerName}";
}

/// <summary>
/// Checks if an entity has endpoints configured (for API tests).
/// </summary>
private bool HasEndpoints(EnvDTE.CodeClass entity)
{
    try
    {
        var attrs = GetAttributesDict(entity);
        if (!attrs.ContainsKey("EndpointsT4")) return false;
        return attrs["EndpointsT4"].Any();
    }
    catch
    {
        return false;
    }
}
#>
