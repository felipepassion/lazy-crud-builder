<#+
// ============================================================================
// Tests.Common.ttinclude — Shared helpers for T4-generated test files.
// Provides auto-generated headers, namespace helpers, and test scaffolding
// utilities used by all layer-specific test templates.
// ============================================================================

/// <summary>Writes the standard auto-generated file header.</summary>
private void WriteAutoGeneratedHeader(string layerName, string entityName)
{
#>
// <auto-generated>
//     This code was generated by a T4 template (Tests.<#= layerName #>.tt).
//     Changes to this file will be lost when the code is regenerated.
//     DO NOT EDIT this file manually.
// </auto-generated>
/// <summary>Auto-generated by LazyCrud. DO NOT EDIT.</summary>
<#+
}

// ------------------------------------------------------------------
// Namespace helpers
// ------------------------------------------------------------------

/// <summary>
/// Builds the test namespace for a given layer relative to the aggregate.
/// Uses the current test project name as the base namespace.
/// E.g. "Lazy.Crud.Products.Tests.Domain.Generated"
/// </summary>
private string GetTestNamespace(string layerSuffix)
{
    var proj = GetCurrentProject();
    return proj.Name.Replace('-', '_').Replace(' ', '_') + ".Generated" +
           (string.IsNullOrWhiteSpace(layerSuffix) ? "" : "." + layerSuffix);
}

/// <summary>
/// Returns the SUT (System Under Test) namespace by replacing segments in
/// the entity namespace. For example Domain → Application.DTO, Entities → Requests.
/// </summary>
private string GetSutNamespace(string entityNamespace, string fromLayer, string toLayer, string fromSub, string toSub)
{
    var ns = entityNamespace;
    if (!string.IsNullOrWhiteSpace(fromLayer) && !string.IsNullOrWhiteSpace(toLayer))
        ns = ns.Replace(fromLayer, toLayer);
    if (!string.IsNullOrWhiteSpace(fromSub) && !string.IsNullOrWhiteSpace(toSub))
        ns = ns.Replace(fromSub, toSub);
    return ns;
}

/// <summary>Sanitises a name to be a valid C# identifier.</summary>
private string SanitizeIdentifier(string name)
{
    if (string.IsNullOrWhiteSpace(name)) return "_";
    var sb = new System.Text.StringBuilder();
    foreach (var c in name)
    {
        if (char.IsLetterOrDigit(c) || c == '_') sb.Append(c);
    }
    var result = sb.ToString();
    if (result.Length == 0 || char.IsDigit(result[0])) result = "_" + result;
    return result;
}

// ------------------------------------------------------------------
// Test class name helpers
// ------------------------------------------------------------------

private string NormalizeTestClassName(string entityName, string suffix = "Tests")
{
    return SanitizeIdentifier(entityName) + "Entity" + suffix;
}

private string NormalizeDtoTestClassName(string entityName)
{
    return SanitizeIdentifier(entityName) + "DtoSerializationTests";
}

// ------------------------------------------------------------------
// Output path helpers
// ------------------------------------------------------------------

/// <summary>Gets the test output subfolder path for generated tests.</summary>
private string GetTestOutputPath()
{
    var basePath = GetGenerationOutputPath();
    if (string.IsNullOrWhiteSpace(basePath))
        return "Generated";
    return basePath;
}

// ------------------------------------------------------------------
// Initialise common variables used by all test templates
// ------------------------------------------------------------------

private string _testAggName;
private List<EnvDTE.CodeClass> _testEntities;
private IEnumerable<IGrouping<string, EnvDTE.CodeClass>> _testGroupEntities;

/// <summary>
/// Bootstraps the standard test variables. Call once at the top of every test template.
/// Sets: _testAggName, _testEntities, _testGroupEntities
/// </summary>
private void InitTestVariables()
{
    _testEntities = GetEntities("Domain", withAttribute: "EndpointsT4");
    var proj = GetCurrentProject();
    var myName = proj.Name.Replace(GetDefaultNamespace() + ".", "").Split('.').First();
    _testAggName = myName + "Agg";
    _testGroupEntities = _testEntities.GroupBy(p => p.Namespace.FullName);
}
#>
